# Telegram bot token, get from BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API key, used for transaction parsing with Llama 3.3 70B
# Get from console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Azure Speech Services, used for Speech-to-Text and Text-to-Speech
# Get from portal.azure.com by creating a Speech resource
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# PostgreSQL connection string
# Local or dev: use the External Database URL from your Postgres provider
# Production web service: use the Internal Database URL for speed
DATABASE_URL=postgresql://user:password@host/dbname
